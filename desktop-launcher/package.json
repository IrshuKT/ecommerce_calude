{
  "name": "ecommerce-calude-launcher",
  "version": "1.0.0",
  "description": "Desktop launcher for ecommerce_calude (Next.js + FastAPI)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.risma.ecommercecalude",
    "productName": "Ecommerce Calude",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      { "from": "resources/backend", "to": "backend" },
      { "from": "resources/frontend", "to": "frontend" },
      { "from": "resources/node", "to": "node" }
    ],
    "files": [
      "main.js",
      "package.json"
    ]
  }
}
